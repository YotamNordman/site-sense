{
  "manifest_version": 3,
  "name": "site-sense",
  "version": "0.1.0",
  "description": "Give your AI coding CLI eyes into web portals",

  "key": "",

  "permissions": [
    "activeTab",
    "scripting",
    "nativeMessaging"
  ],

  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "site-sense",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
